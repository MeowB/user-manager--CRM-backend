{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
	"ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
	"rootDir": "src",
    "outDir": "dist",
  },
  "include": ["src"]
}
